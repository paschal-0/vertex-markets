NODE_ENV=development
TENANT_HEADER=x-tenant-id
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

POSTGRES_URL=postgresql://vertex:change_me@127.0.0.1:5432/vertex_main
REDIS_URL=redis://127.0.0.1:6379

WEB_PORT=3000
MAIN_API_PORT=4000
CHART_API_PORT=4100

UPSTREAM_FEED_MODE=mock
SQLITE_DB_PATH=./apps/chart-api/data/market.db

