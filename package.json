    "start:main-api": "pnpm --filter @vertex/main-api start",
    "start:chart-api": "pnpm --filter @vertex/chart-api start"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

