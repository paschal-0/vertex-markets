{
  "name": "vunex-markets-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Vunex Markets dual-system fintech platform monorepo.",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
